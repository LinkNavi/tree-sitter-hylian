{
  "name": "tree-sitter-hylian",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for the Hylian programming language",
  "repository": {
    "type": "git",
    "url": "https://github.com/LinkNavi/tree-sitter-hylian"
  },
  "license": "MIT",
  "main": "bindings/node",
  "keywords": [
    "tree-sitter",
    "hylian",
    "parser"
  ],
  "dependencies": {
    "nan": "^2.18.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.22.0"
  },
  "tree-sitter": [
    {
      "scope": "source.hylian",
      "file-types": [
        "hy"
      ],
      "highlights": "queries/highlights.scm",
      "injection-regex": "^hylian$"
    }
  ],
  "scripts": {
    "build": "tree-sitter generate && node-gyp build",
    "test": "tree-sitter test",
    "parse": "tree-sitter parse"
  }
}
